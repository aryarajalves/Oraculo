# Fonte Oculta — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA faça commit do arquivo .env — ele já está no .gitignore.

# ── OpenAI / GPT Image 2 (geração de imagens e texto) ────────────────────────
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_chave_openai_aqui

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── Meta / Instagram Graph API ────────────────────────────────────────────────
# Gere em: https://developers.facebook.com → seu app → Graph API Explorer
META_ACCESS_TOKEN=seu_token_meta_aqui
INSTAGRAM_ACCOUNT_ID=seu_instagram_account_id_aqui
FACEBOOK_PAGE_ID=seu_facebook_page_id_aqui

# ── Credenciais Instagram (login direto) ──────────────────────────────────────
INSTAGRAM_USERNAME=seu_usuario_instagram
INSTAGRAM_PASSWORD=sua_senha_instagram

# ── ImgBB (hospedagem temporária de imagens para Instagram API) ───────────────
# Obtenha em: https://api.imgbb.com
IMGBB_API_KEY=sua_chave_imgbb_aqui

# ── Apify (scraping e radar) ──────────────────────────────────────────────────
# Obtenha em: https://console.apify.com/
APIFY_API_KEY=sua_chave_apify_aqui

# ── Notion (integração com dashboard/banco de conteúdo) ───────────────────────
# Obtenha em: https://www.notion.so/my-integrations
NOTION_TOKEN=seu_token_notion_aqui

# ── Backblaze B2 (armazenamento de arquivos) ──────────────────────────────────
# Obtenha em: https://www.backblaze.com/b2/docs/
B2_KEY_ID=seu_key_id_b2
B2_APPLICATION_KEY=sua_application_key_b2
B2_BUCKET_NAME=nome_do_seu_bucket
B2_ENDPOINT=https://s3.us-west-000.backblazeb2.com

# ── ElevenLabs (geração de áudio) ─────────────────────────────────────────────
# Obtenha em: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui

# ── Fal.ai (geração de imagens alternativa) ───────────────────────────────────
# Obtenha em: https://fal.ai/dashboard/keys
FAL_KEY=sua_chave_fal_aqui

# ── Dashboard Login ────────────────────────────────────────────────────────────
DASHBOARD_USER=jordao
DASHBOARD_PASS=troque_para_senha_forte
SESSION_SECRET=troque_para_string_aleatoria_longa

# ── Banco de Dados PostgreSQL (pgvector) ──────────────────────────────────────
# [OPCIONAL] Se rodar via Docker Compose, as variáveis padrão já estão prontas.
# Se rodar local, defina os valores adequados.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=oracle_manager
